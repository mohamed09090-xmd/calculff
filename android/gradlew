#!/usr/bin/env sh
set -eu
APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROP="$APP_HOME/gradle/wrapper/gradle-wrapper.properties"
URL=$(sed -n 's/^distributionUrl=//p' "$PROP" | sed 's#\\:#:#g')
VERSION=$(printf '%s' "$URL" | sed -n 's#.*gradle-\([0-9.]*\)-bin.zip#\1#p')
CACHE="${GRADLE_USER_HOME:-$HOME/.gradle}/wrapper/manual/gradle-$VERSION"
BIN="$CACHE/gradle-$VERSION/bin/gradle"
if [ ! -x "$BIN" ]; then
  mkdir -p "$CACHE"
  ZIP="$CACHE/gradle.zip"
  if command -v curl >/dev/null 2>&1; then
    curl -L "$URL" -o "$ZIP"
  elif command -v wget >/dev/null 2>&1; then
    wget "$URL" -O "$ZIP"
  else
    echo "curl or wget is required to download Gradle" >&2
    exit 1
  fi
  unzip -q "$ZIP" -d "$CACHE"
  rm -f "$ZIP"
fi
exec "$BIN" "$@"
